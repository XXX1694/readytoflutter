# ──────────────────────────────────────────────────────────────────────────────
# ReadyToFlutter — frontend env (copy to .env.local for local overrides)
# ──────────────────────────────────────────────────────────────────────────────

# Backend API base URL. Leave EMPTY to keep the dev-friendly default (`/api`,
# resolved via the Vite proxy to localhost:3001). Set in production builds
# (e.g. via a GitHub Pages repo Variable) to point at your deployed backend.
# Example: https://readytoflutter-api.onrender.com/api
VITE_API_BASE_URL=

# Optional GitHub Pages fallback. If VITE_API_BASE_URL is unset and the page
# is served from *.github.io, the runtime falls back to this URL. Used so a
# fork deployed to Pages can still talk to a known backend without having to
# set VITE_API_BASE_URL explicitly. Leave empty to disable the fallback (the
# app keeps working in anonymous-only mode).
# VITE_PROD_API_FALLBACK_URL=https://readytoflutter.onrender.com/api

# Override the base path. Useful when deploying to a non-root path like
# /readytoflutter/. Auto-inferred from GITHUB_REPOSITORY in CI; you almost
# never need to set this manually.
# VITE_BASE_PATH=/readytoflutter/

# ──────────────────────────────────────────────────────────────────────────────
# Analytics (optional)
# ──────────────────────────────────────────────────────────────────────────────
# Pick AT MOST one provider. With neither set, src/lib/analytics.js stays a
# no-op (events log to the console in dev, ship nothing in prod). Pageviews,
# signup, login, study_session_start/complete, mock_complete, and
# ai_grade_used are already wired — flipping the switch lights them up.

# PostHog (free tier covers solo projects). Get a Project API Key from
# https://posthog.com/. Host defaults to us.i.posthog.com.
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# Plausible (alternative to PostHog — privacy-first, fewer dimensions).
# Set the verified site domain you registered in Plausible.
# VITE_PLAUSIBLE_DOMAIN=prepiroshi.example.com
