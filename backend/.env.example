# ──────────────────────────────────────────────────────────────────────────────
# ReadyToFlutter — backend env (copy to .env and fill in)
# ──────────────────────────────────────────────────────────────────────────────

# Port the Express server listens on. Default 3001.
PORT=3001

# Production indicator. Enables: trust-proxy (X-Forwarded-* from Render/etc),
# HSTS header, stricter behavior. Leave unset locally.
# NODE_ENV=production

# JWT secret — REQUIRED in production. Use a 64+ char random string. Tokens
# signed with one secret are invalid under another, so rotating logs
# everyone out.
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Locally a stable secret is auto-persisted to backend/data/.jwt-secret if
# you don't set this.
# JWT_SECRET=your-64-char-random-secret-here

# JWT expiry. Defaults to 7d. Use any vercel/ms duration string (e.g. "1d",
# "12h", "30d"). Shorter = safer, but users sign in more often.
# JWT_EXPIRES_IN=7d

# Lock CORS to a single origin in production (e.g. your GitHub Pages URL).
# In dev, leaving this unset allows all origins so the Vite proxy works.
# FRONTEND_ORIGIN=https://<username>.github.io

# Anthropic API key for AI answer grading in mock interviews. When unset,
# /api/ai/health returns { enabled: false } and the frontend hides the
# AI-check button — so the rest of the app keeps working without it.
# This key NEVER leaves the server: the frontend posts the user's answer to
# /api/ai/grade, the server fetches the reference answer from SQLite, calls
# Anthropic with claude-haiku-4-5, and returns a structured grade.
# Get a key at https://console.anthropic.com/. Keep it secret.
# ANTHROPIC_API_KEY=sk-ant-...
